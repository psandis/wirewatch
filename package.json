{
  "name": "wirewatch",
  "version": "0.1.1",
  "description": "Network traffic monitoring CLI. Local-first, AI-assisted anomaly detection.",
  "type": "module",
  "bin": {
    "ww": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "cli": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
